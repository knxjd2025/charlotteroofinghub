# Google API Key — Required for the Instant Roof Estimate feature
# Enable these APIs in Google Cloud Console:
#   - Places API (New)
#   - Geocoding API
#   - Maps Static API
#   - Solar API
GOOGLE_API_KEY=your_google_api_key_here

# GoHighLevel Webhook URL — For lead submission to CRM
GHL_WEBHOOK_URL=your_ghl_webhook_url_here

# Database
DATABASE_URL=your_database_url_here
